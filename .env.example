# Blizzard API
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here
BLIZZARD_REALM_ID=1370   # Connected realm ID (1370 = Stormrage-US as example)

# Database
DATABASE_URL=postgresql://wow_user:wow_pass@localhost:5432/wow_auctions

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# Airflow (generate with: python -c "import base64,os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())")
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW_SECRET_KEY=your_secret_key_here

# App
APP_ENV=development
